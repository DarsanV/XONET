PORT=4000
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/xonet
USE_MEMORY_DB=false

JWT_SECRET=generate-a-long-random-secret
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_EXPIRES=30d

CLIENT_URL=http://localhost:3000

# Email (optional in dev — links are logged to the console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=XONET <noreply@xonet.io>
